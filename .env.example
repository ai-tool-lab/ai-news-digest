# =============================================================
#  AI News Digest - 環境変数サンプル
#  このファイルをコピーして「.env」という名前で保存し、
#  実際の値を入力してください。
#  ※ .env は絶対にGitにコミットしないでください。
# =============================================================

# Discord の Webhook URL
DISCORD_WEBHOOK_URL=ここにDiscordのWebhook URLを入力

# Claude Console (Anthropic) の APIキー
ANTHROPIC_API_KEY=ここにClaude Console APIキーを入力
